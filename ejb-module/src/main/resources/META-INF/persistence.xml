<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!--
        Unidade de persistência usada em produção (WildFly/GlassFish).
        O datasource 'jdbc/desafioDS' deve ser configurado no servidor de aplicação.
    -->
    <persistence-unit name="desafio-pu" transaction-type="JTA">
        <jta-data-source>jdbc/desafioDS</jta-data-source>
        <class>com.desafio.ejb.model.Beneficio</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <!-- Dialeto PostgreSQL -->
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

</persistence>
